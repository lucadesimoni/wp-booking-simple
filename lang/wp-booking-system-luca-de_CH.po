msgid "Dear {guest_name},\n\nThank you for your booking! We are pleased to confirm your reservation.\n\n{booking_details}\n\nYou can manage or cancel your booking using the link below:\n\n{manage_link}\n\nWe look forward to welcoming you!\n\nBest regards,\n{site_name}"
msgstr "Liebe/r {guest_name},\n\nvielen Dank für Ihre Buchung! Wir freuen uns, Ihre Reservierung zu bestätigen.\n\n{booking_details}\n\nSie können Ihre Buchung über den folgenden Link verwalten oder stornieren:\n\n{manage_link}\n\nWir freuen uns darauf, Sie begrüßen zu dürfen!\n\nMit freundlichen Grüßen,\n{site_name}"

msgid "Dear {guest_name},\n\nThis is a friendly reminder about the balance for your booking.\n\n{booking_details}\n\nAmount paid: {amount_paid}\nOutstanding balance: {amount_due}\n\nYou can review your booking using the link below:\n\n{manage_link}\n\nThank you,\n{site_name}"
msgstr "Liebe/r {guest_name},\n\ndies ist eine freundliche Erinnerung an den offenen Betrag für Ihre Buchung.\n\n{booking_details}\n\nBezahlter Betrag: {amount_paid}\nOffener Betrag: {amount_due}\n\nSie können Ihre Buchung über den folgenden Link einsehen:\n\n{manage_link}\n\nVielen Dank,\n{site_name}"

msgid "Dear {guest_name},\n\nYour booking has been cancelled as requested.\n\nWe hope to welcome you in the future!\n\nBest regards,\n{site_name}"
msgstr "Liebe/r {guest_name},\n\nIhre Buchung wurde wie gewünscht storniert.\n\nWir hoffen, Sie in Zukunft begrüßen zu dürfen!\n\nMit freundlichen Grüßen,\n{site_name}"

